# Copy to .env if you need overrides (optional)
PORT=8787
# Writable app-data root (для packaged по умолчанию на Windows: %LOCALAPPDATA%/ERI DB Search/data)
APP_DATA_DIR=./data
# SQLite path (absolute или relative to APP_DATA_DIR)
DATABASE_PATH=app.db
# Static client assets path (absolute или relative to app root)
CLIENT_DIST=../client/dist
# Browser auto-open: packaged default = on. Set 0 to disable.
AUTO_OPEN_BROWSER=0

# Hybrid materialization policy thresholds (pairs = uniqueBases * uniqueAdds)
MATERIALIZE_WARN_PAIRS=250000
MATERIALIZE_LAZY_PAIRS=1000000
MATERIALIZE_REJECT_PAIRS=5000000
